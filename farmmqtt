#!/usr/bin/env bash
# farmmqtt — smart-farm-mqtt 서비스 관리 CLI

BACKEND_LABEL="com.smartfarm-mqtt.backend"
FRONTEND_LABEL="com.smartfarm-mqtt.frontend"
LOG_DIR="/Users/ohjeongseok/Projects/smart-farm-mqtt/logs"

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

_is_running() {
  launchctl list "$1" 2>/dev/null | grep -q '"PID"'
}

_service_status() {
  local label=$1
  local name=$2
  if _is_running "$label"; then
    local pid
    pid=$(launchctl list "$label" 2>/dev/null | grep '"PID"' | awk '{print $3}' | tr -d ',')
    echo -e "  ${GREEN}●${NC} ${name} — ${GREEN}실행 중${NC} (PID: ${pid})"
  else
    local last_exit
    last_exit=$(launchctl list "$label" 2>/dev/null | grep '"LastExitStatus"' | awk '{print $3}' | tr -d ',')
    if [ -z "$last_exit" ]; then
      echo -e "  ${YELLOW}○${NC} ${name} — ${YELLOW}등록되지 않음${NC}"
    else
      echo -e "  ${RED}●${NC} ${name} — ${RED}중지됨${NC} (마지막 종료코드: ${last_exit})"
    fi
  fi
}

_check_infra() {
  echo ""
  echo -e "${CYAN}[ 인프라 서비스 ]${NC}"
  # PostgreSQL
  if lsof -i :5432 -sTCP:LISTEN > /dev/null 2>&1; then
    echo -e "  ${GREEN}●${NC} PostgreSQL  — ${GREEN}실행 중${NC} (:5432)"
  else
    echo -e "  ${RED}●${NC} PostgreSQL  — ${RED}중지됨${NC}"
  fi
  # Redis
  if lsof -i :6379 -sTCP:LISTEN > /dev/null 2>&1; then
    echo -e "  ${GREEN}●${NC} Redis       — ${GREEN}실행 중${NC} (:6379)"
  else
    echo -e "  ${RED}●${NC} Redis       — ${RED}중지됨${NC}"
  fi
  # MQTT
  if lsof -i :1883 -sTCP:LISTEN > /dev/null 2>&1; then
    echo -e "  ${GREEN}●${NC} MQTT        — ${GREEN}실행 중${NC} (:1883)"
  else
    echo -e "  ${RED}●${NC} MQTT        — ${RED}중지됨${NC}"
  fi
}

cmd_status() {
  echo ""
  echo -e "${CYAN}[ 애플리케이션 서비스 ]${NC}"
  _service_status "$BACKEND_LABEL"  "Backend  (NestJS :3100)"
  _service_status "$FRONTEND_LABEL" "Frontend (Vite   :5174)"
  _check_infra
  echo ""
}

cmd_start() {
  local target=${1:-all}
  case $target in
    backend)
      echo "백엔드 시작 중..."
      launchctl load -w ~/Library/LaunchAgents/${BACKEND_LABEL}.plist 2>/dev/null || \
        launchctl kickstart -p "gui/$(id -u)/${BACKEND_LABEL}" 2>/dev/null || true
      echo -e "${GREEN}백엔드 시작 완료${NC}"
      ;;
    frontend)
      echo "프론트엔드 시작 중..."
      launchctl load -w ~/Library/LaunchAgents/${FRONTEND_LABEL}.plist 2>/dev/null || \
        launchctl kickstart -p "gui/$(id -u)/${FRONTEND_LABEL}" 2>/dev/null || true
      echo -e "${GREEN}프론트엔드 시작 완료${NC}"
      ;;
    all|*)
      echo "전체 서비스 시작 중..."
      launchctl load -w ~/Library/LaunchAgents/${BACKEND_LABEL}.plist 2>/dev/null || true
      launchctl load -w ~/Library/LaunchAgents/${FRONTEND_LABEL}.plist 2>/dev/null || true
      sleep 3
      cmd_status
      ;;
  esac
}

cmd_stop() {
  local target=${1:-all}
  case $target in
    backend)
      echo "백엔드 중지 중..."
      launchctl unload ~/Library/LaunchAgents/${BACKEND_LABEL}.plist 2>/dev/null || true
      echo -e "${YELLOW}백엔드 중지 완료${NC}"
      ;;
    frontend)
      echo "프론트엔드 중지 중..."
      launchctl unload ~/Library/LaunchAgents/${FRONTEND_LABEL}.plist 2>/dev/null || true
      echo -e "${YELLOW}프론트엔드 중지 완료${NC}"
      ;;
    all|*)
      echo "전체 서비스 중지 중..."
      launchctl unload ~/Library/LaunchAgents/${BACKEND_LABEL}.plist 2>/dev/null || true
      launchctl unload ~/Library/LaunchAgents/${FRONTEND_LABEL}.plist 2>/dev/null || true
      echo -e "${YELLOW}전체 서비스 중지 완료${NC}"
      ;;
  esac
}

cmd_restart() {
  local target=${1:-all}
  echo "재시작 중..."
  cmd_stop "$target"
  sleep 2
  cmd_start "$target"
}

cmd_logs() {
  local target=${1:-backend}
  local lines=${2:-50}
  case $target in
    backend)
      echo -e "${CYAN}=== Backend 로그 (최근 ${lines}줄) ===${NC}"
      tail -n "$lines" "${LOG_DIR}/backend.stdout.log" 2>/dev/null
      echo -e "${RED}--- stderr ---${NC}"
      tail -n 20 "${LOG_DIR}/backend.stderr.log" 2>/dev/null
      ;;
    frontend)
      echo -e "${CYAN}=== Frontend 로그 (최근 ${lines}줄) ===${NC}"
      tail -n "$lines" "${LOG_DIR}/frontend.stdout.log" 2>/dev/null
      ;;
    follow|f)
      echo -e "${CYAN}=== 실시간 로그 (Ctrl+C로 종료) ===${NC}"
      tail -f "${LOG_DIR}/backend.stdout.log" "${LOG_DIR}/frontend.stdout.log"
      ;;
    *)
      echo "사용법: farmmqtt logs [backend|frontend|follow] [줄수]"
      ;;
  esac
}

cmd_help() {
  echo ""
  echo -e "${CYAN}farmmqtt — smart-farm-mqtt 서비스 관리 CLI${NC}"
  echo ""
  echo "사용법: farmmqtt <명령> [대상]"
  echo ""
  echo "명령:"
  echo "  status              전체 서비스 상태 확인"
  echo "  start  [all|backend|frontend]  서비스 시작"
  echo "  stop   [all|backend|frontend]  서비스 중지"
  echo "  restart[all|backend|frontend]  서비스 재시작"
  echo "  logs   [backend|frontend|follow] [줄수]  로그 확인"
  echo ""
  echo "예시:"
  echo "  farmmqtt status"
  echo "  farmmqtt start"
  echo "  farmmqtt restart backend"
  echo "  farmmqtt logs follow"
  echo "  farmmqtt logs backend 100"
  echo ""
}

# 현재 실행 중인 npm 프로세스가 있으면 먼저 launchd에 등록
_bootstrap() {
  if ! launchctl list "$BACKEND_LABEL" > /dev/null 2>&1; then
    launchctl load ~/Library/LaunchAgents/${BACKEND_LABEL}.plist 2>/dev/null || true
  fi
  if ! launchctl list "$FRONTEND_LABEL" > /dev/null 2>&1; then
    launchctl load ~/Library/LaunchAgents/${FRONTEND_LABEL}.plist 2>/dev/null || true
  fi
}

case "${1:-}" in
  status|st)       cmd_status ;;
  start)           cmd_start "${2:-all}" ;;
  stop)            cmd_stop "${2:-all}" ;;
  restart|rs)      cmd_restart "${2:-all}" ;;
  logs|log)        cmd_logs "${2:-backend}" "${3:-50}" ;;
  help|--help|-h)  cmd_help ;;
  "")              cmd_status ;;
  *)
    echo -e "${RED}알 수 없는 명령: $1${NC}"
    cmd_help
    exit 1
    ;;
esac
