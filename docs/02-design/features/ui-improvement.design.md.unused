```typescript
// 탭 정의 (실제 구현)
const mainTabs = [
  { path: '/devices', icon: '📦', label: '장비' },
  { path: '/sensors', icon: '🌡️', label: '센서' },
  { path: '/automation', icon: '⚙️', label: '자동화' },
