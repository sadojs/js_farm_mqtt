# Database
DATABASE_URL=postgresql://smartfarm:smartfarm123@localhost:5432/smartfarm_mqtt

# Redis
REDIS_URL=redis://localhost:6379

# MQTT Broker
MQTT_URL=mqtt://localhost:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# Zigbee2MQTT
ZIGBEE2MQTT_URL=http://localhost:8080

# OpenWeather API
# Get your API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# 기상청 API
# Get your API key from: https://www.data.go.kr/
KMA_API_KEY=your_kma_api_key_here

# Server Configuration
PORT=3100
NODE_ENV=development

# JWT Secret (for authentication)
JWT_SECRET=your_jwt_secret_here_change_in_production

# rpi-golden-image-system: Pi first-boot register-tunnel-key 인증 토큰
# 같은 값을 /etc/smartfarm/bootstrap.token 으로 골든 이미지에 사전 주입
BOOTSTRAP_TOKEN=change_me_to_a_random_64char_string

# rpi-golden-image-system: reverse SSH tunnel 자동 설정
# Pi가 autossh로 접속할 서버 정보 (first-boot-init이 응답으로 받음)
TUNNEL_SERVER_HOST=172.30.1.42
TUNNEL_SERVER_USER=your_server_user
TUNNEL_SERVER_PORT=22
TUNNEL_AUTHORIZED_KEYS_PATH=/Users/you/.ssh/authorized_keys
TUNNEL_REMOTE_PORT_BASE=22200

# ssh-proxy 웹콘솔: 서버→Pi reverse tunnel SSH 접속 (lgwadmin 통일 정책)
# 코드 기본값 'lgw-dev'는 PI에 존재하지 않으므로 반드시 override 필요
SSH_TUNNEL_USER=lgwadmin
SSH_TUNNEL_KEY_PATH=/Users/you/.ssh/id_rpi_lgw

# CORS
CORS_ORIGIN=http://localhost:5174

# WebSocket
WS_PORT=3101

# Notification Settings
ENABLE_NOTIFICATIONS=true
NOTIFICATION_EMAIL=admin@smartfarm.com
