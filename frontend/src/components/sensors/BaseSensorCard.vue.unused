<template>
  <div class="sensor-card" :class="[`status-${status}`, { disabled: !enabled }]">
    <div class="sensor-header">
      <div class="sensor-icon">
        <slot name="icon">
          <span class="icon-placeholder">📊</span>
        </slot>
      </div>
      <div class="sensor-info">
        <h3 class="sensor-title">{{ title }}</h3>
        <p class="sensor-subtitle">{{ subtitle }}</p>
      </div>
      <div class="sensor-status-badge" :class="`badge-${status}`">
        {{ statusText }}
      </div>
    </div>

    <div class="sensor-value-container">
      <div class="sensor-value">
        <span class="value">{{ displayValue }}</span>
        <span class="unit">{{ unit }}</span>
      </div>

      <div class="sensor-trend" v-if="trend">
        <span class="trend-icon" :class="`trend-${trend}`">
          {{ trendIcon }}
        </span>
        <span class="trend-value">{{ trendValue }}</span>
      </div>
    </div>

    <div class="sensor-thresholds">
      <div class="threshold-bar">
        <div
          class="threshold-indicator"
          :style="{ left: indicatorPosition + '%' }"
        ></div>
        <div class="threshold-ranges">
          <span class="range-label min">{{ thresholds.min }}</span>
          <span class="range-label max">{{ thresholds.max }}</span>
        </div>
      </div>
    </div>

    <div class="sensor-chart" v-if="showChart">
      <slot name="chart">
        <!-- Chart will be injected here -->
      </slot>
    </div>

    <div class="sensor-actions">
      <button @click="$emit('refresh')" class="btn-icon">🔄</button>
      <button @click="$emit('settings')" class="btn-icon">⚙️</button>
    </div>
  </div>
</template>

<script setup lang="ts">
import { computed } from 'vue';

interface Props {
  title: string;
  subtitle?: string;
  value: number;
  unit: string;
  status: 'normal' | 'warning' | 'critical' | 'offline';
  enabled?: boolean;
  thresholds: {
    min: number;
    max: number;
  };
  trend?: 'up' | 'down' | 'stable';
  trendValue?: string;
  showChart?: boolean;
}

const props = withDefaults(defineProps<Props>(), {
  enabled: true,
  showChart: false,
});

defineEmits<{
  refresh: [];
  settings: [];
}>();

const displayValue = computed(() => {
  return props.value.toFixed(1);
});

const statusText = computed(() => {
  const statusMap = {
    normal: '정상',
    warning: '경고',
    critical: '위험',
    offline: '오프라인',
  };
  return statusMap[props.status];
});

const trendIcon = computed(() => {
  const iconMap = {
    up: '↑',
    down: '↓',
    stable: '→',
  };
  return props.trend ? iconMap[props.trend] : '';
});

const indicatorPosition = computed(() => {
  const { value, thresholds } = props;
  const range = thresholds.max - thresholds.min;
  const position = ((value - thresholds.min) / range) * 100;
  return Math.max(0, Math.min(100, position));
});
</script>

