  background: var(--automation-bg);
  color: #f57c00;
}

.badge-critical {
  background: #ffebee;
  color: #c62828;
}

.badge-offline {
  background: #f5f5f5;
  color: #757575;
}

.sensor-value-container {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16px;
}

.sensor-value {
  display: flex;
  align-items: baseline;
  gap: 4px;
}

.value {
  font-size: 36px;
  font-weight: 700;
  color: var(--text-primary);
}

.unit {
  font-size: 18px;
  color: var(--text-link);
}

.sensor-trend {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 14px;
}

.trend-icon {
  font-size: 16px;
}

.trend-up {
  color: #f44336;
}

.trend-down {
  color: #2196f3;
}

.trend-stable {
  color: #9e9e9e;
}

.sensor-thresholds {
  margin-bottom: 16px;
}

.threshold-bar {
  height: 8px;
  background: linear-gradient(to right, #4caf50 0%, #ffeb3b 50%, #f44336 100%);
  border-radius: 4px;
  position: relative;
  margin-bottom: 8px;
}

.threshold-indicator {
  position: absolute;
  top: -4px;
  width: 16px;
  height: 16px;
  background: var(--bg-card);
  border: 3px solid var(--text-primary);
  border-radius: 50%;
  transform: translateX(-50%);
  transition: left 0.3s ease;
}

.threshold-ranges {
  display: flex;
  justify-content: space-between;
  font-size: 12px;
  color: var(--text-link);
}

.sensor-chart {
  margin: 16px 0;
  height: 120px;
}

.sensor-actions {
  display: flex;
  gap: 8px;
  justify-content: flex-end;
}

.btn-icon {
  width: 36px;
  height: 36px;
  border: none;
  background: #f5f5f5;
  border-radius: 8px;
  cursor: pointer;
  font-size: 16px;
  transition: background 0.2s;
}

.btn-icon:hover {
