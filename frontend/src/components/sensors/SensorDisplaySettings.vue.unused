<template>
  <div v-if="show" class="modal-overlay" @click.self="closeModal">
    <div class="modal-container">
      <div class="modal-header">
        <h2>⚙️ 센서 표시 설정</h2>
        <button class="close-btn" @click="closeModal">✕</button>
      </div>

      <div class="modal-body">
        <p class="description">
          대시보드에 표시할 센서 타입을 선택하세요. 선택한 센서만 화면에 표시됩니다.
        </p>

        <div class="sensor-types-list">
          <div
            v-for="sensorType in availableSensorTypes"
            :key="sensorType.id"
            class="sensor-type-item"
            :class="{ selected: localSelectedSensors.includes(sensorType.id) }"
            @click="toggleSensor(sensorType.id)"
          >
            <input
              type="checkbox"
              :checked="localSelectedSensors.includes(sensorType.id)"
              @click.stop
              @change="toggleSensor(sensorType.id)"
            />
            <div class="sensor-type-icon">{{ sensorType.icon }}</div>
            <div class="sensor-type-info">
              <h4>{{ sensorType.name }}</h4>
              <p>{{ sensorType.description }}</p>
            </div>
            <span class="sensor-count">{{ sensorType.count }}개</span>
          </div>
        </div>

        <div class="quick-actions">
          <button class="quick-btn" @click="selectAll">전체 선택</button>
          <button class="quick-btn" @click="deselectAll">전체 해제</button>
          <button class="quick-btn" @click="selectDefault">기본값</button>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn-secondary" @click="closeModal">취소</button>
        <button class="btn-primary" @click="saveSettings">
          적용 ({{ localSelectedSensors.length }}개 선택)
        </button>
      </div>
    </div>
  </div>
</template>

<script setup lang="ts">
import { ref, watch } from 'vue'

interface SensorType {
  id: string
  name: string
  icon: string
  description: string
  count: number
}

const props = defineProps<{
  show: boolean
  selectedSensors: string[]
}>()

const emit = defineEmits<{
  close: []
  update: [sensorTypes: string[]]
}>()

const availableSensorTypes = ref<SensorType[]>([
  {
    id: 'temperature',
    name: '온도 센서',
    icon: '🌡️',
    description: '하우스 내부 온도 측정',
    count: 12
  },
  {
    id: 'humidity',
    name: '습도 센서',
    icon: '💧',
    description: '대기 중 습도 측정',
    count: 12
  },
  {
    id: 'co2',
    name: 'CO2 센서',
    icon: '🌫️',
    description: '이산화탄소 농도 측정',
    count: 8
  },
  {
    id: 'light',
    name: '조도 센서',
    icon: '💡',
    description: '빛의 세기 측정',
    count: 10
  },
  {
    id: 'soil_moisture',
    name: '토양수분 센서',
    icon: '🌱',
    description: '토양 수분 함량 측정',
    count: 15
  },
  {
    id: 'ph',
    name: 'PH 센서',
    icon: '⚗️',
    description: '토양 산도 측정',
    count: 6
  },
  {
    id: 'ec',
    name: 'EC 센서',
    icon: '⚡',
    description: '전기전도도 측정',
    count: 6
  }
])

const localSelectedSensors = ref<string[]>([...props.selectedSensors])

watch(
  () => props.selectedSensors,
  (newValue) => {
    localSelectedSensors.value = [...newValue]
  }
)

const toggleSensor = (sensorId: string) => {
  const index = localSelectedSensors.value.indexOf(sensorId)
  if (index === -1) {
    localSelectedSensors.value.push(sensorId)
  } else {
    localSelectedSensors.value.splice(index, 1)
  }
}

const selectAll = () => {
  localSelectedSensors.value = availableSensorTypes.value.map(s => s.id)
}

const deselectAll = () => {
  localSelectedSensors.value = []
}

const selectDefault = () => {
  localSelectedSensors.value = ['temperature', 'humidity', 'co2', 'light']
}

const saveSettings = () => {
  emit('update', localSelectedSensors.value)
  closeModal()
}

const closeModal = () => {
  emit('close')
}
</script>

<style scoped>
