  font-size: 16px;
  font-weight: 600;
  color: #333;
  margin: 0 0 4px 0;
}

.sensor-type-info p {
  font-size: 13px;
  color: #666;
  margin: 0;
}

.sensor-count {
  font-size: 14px;
  font-weight: 600;
  color: #4caf50;
  flex-shrink: 0;
}

.quick-actions {
  display: flex;
  gap: 8px;
  padding-top: 16px;
  border-top: 1px solid #e0e0e0;
}

.quick-btn {
  flex: 1;
  padding: 8px 16px;
  background: #f5f5f5;
  border: none;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 500;
  cursor: pointer;
  transition: all 0.2s;
}

.quick-btn:hover {
  background: #e0e0e0;
}

.modal-footer {
  display: flex;
  justify-content: flex-end;
